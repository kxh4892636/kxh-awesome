{
	"name": "react-template",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --hot index.ts",
		"build": "bun build ./app/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
		"start": "NODE_ENV=production bun index.ts"
	},
	"dependencies": {
		"@tanstack/react-query": "^5.90.18",
		"es-toolkit": "^1.44.0",
		"immer": "^11.1.3",
		"react": "^18",
		"react-dom": "^18",
		"react-router": "^7.12.0",
		"zod": "^4.3.5",
		"zustand": "^5.0.10"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^18",
		"@types/react-dom": "^18",
		"bun-plugin-tailwind": "^0.1.2",
		"tailwindcss": "^4.1.18"
	}
}
